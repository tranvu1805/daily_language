# Encoding: utf-8
default_platform(:android)

platform :android do

  desc "Chạy unit tests"
  lane :test do
    gradle(project_dir: "android", task: "test")
  end

  desc "Build AAB và upload lên Play Store Internal track"
  lane :deploy_internal do
    def safe_version_codes(track)
      google_play_track_version_codes(track: track)
    rescue => e
      UI.message("Track '#{track}' skip: #{e.message}")
      []
    end

    all_codes = [
      safe_version_codes("internal"),
      safe_version_codes("alpha"),
      safe_version_codes("beta"),
      safe_version_codes("production"),
      safe_version_codes("draft"),      # ← thêm draft track
    ].flatten.compact

    next_version_code = (all_codes.empty? ? 0 : all_codes.max) + 1
    UI.message("All known version codes: #{all_codes.sort.inspect}")
    UI.message("Using version code: #{next_version_code}")

    supply(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      version_code: next_version_code,
      release_status: "draft",
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )

    if ENV["SLACK_WEBHOOK"]
      slack(
        message: "Android build ##{next_version_code} uploaded to Internal!",
        webhook_url: ENV["SLACK_WEBHOOK"],
        success: true
      )
    end
  end

  desc "Promote từ Internal lên Production"
  lane :deploy_production do
    supply(
      track: "internal",
      track_promote_to: "production",
      rollout: "0.1",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
    )
  end

  error do |lane, exception|
    if ENV["SLACK_WEBHOOK"]
      slack(
        message: "Android #{lane} FAILED: #{exception.message}",
        webhook_url: ENV["SLACK_WEBHOOK"],
        success: false
      )
    end
  end
end